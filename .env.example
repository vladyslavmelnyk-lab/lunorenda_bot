# Скопіюй у .env і заповни (для локального запуску).
# У GitHub Actions ці ж значення задаються як Secrets.

# Токен Telegram-бота від @BotFather
TELEGRAM_BOT_TOKEN=

# Твій chat_id (дізнатись: напиши боту, тоді відкрий
# https://api.telegram.org/bot<TOKEN>/getUpdates і знайди "chat":{"id":...})
TELEGRAM_CHAT_ID=

# Безкоштовний ключ OpenRouteService: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# DRY_RUN=1 — нічого не шле в Telegram, лише друкує в консоль (для тестів)
DRY_RUN=
